[Unit]
Description=TheOwls PI Display Screen
Wants=graphical.target
After=graphical.target

[Service]
Environment=DISPLAY=:0.0
Environment=XAUTHORITY=/home/pi/.Xauthority
Type=simple
ExecStart=/usr/bin/python3 /home/pi/dashdisplay/eDisplay.py
Restart=on-abort
User=pi
Group=pi

[Install]
WantedBy=graphical.target
